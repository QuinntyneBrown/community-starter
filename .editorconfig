root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,ts,html,scss,css,json,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.cs]
indent_size = 4
dotnet_analyzer_diagnostic.category-Style.severity = suggestion
dotnet_diagnostic.IDE0005.severity = warning

[backend/src/CommunityStarter.Infrastructure/Persistence/Migrations/*.cs]
generated_code = true
