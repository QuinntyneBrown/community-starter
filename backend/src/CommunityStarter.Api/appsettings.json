{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Community": ""
  },
  "Security": {
    "TokenPepper": ""
  },
  "Migration": {
    "ApplyOnStartup": false
  },
  "Runtime": {
    "Role": "all"
  },
  "Jobs": {
    "BatchSize": 20,
    "MaximumAttempts": 8,
    "PollIntervalMilliseconds": 1000,
    "LeaseSeconds": 60
  },
  "DevelopmentActions": {
    "ExposeTokens": false
  },
  "AllowedHosts": "*"
}
