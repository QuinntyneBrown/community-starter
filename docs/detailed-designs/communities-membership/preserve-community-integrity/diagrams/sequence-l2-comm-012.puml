@startuml
title UML sequence behaviour — Enforce limits and concurrency
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Community Member" as actor
box "Frontend — Member Web Application" #E0F2FE
  participant "PreserveCommunityIntegritySurface" as surface
  participant "PreserveCommunityIntegrityClient" as client
end box
box "Backend — Community API" #D1FADF
  participant "PreserveCommunityIntegrityEndpoint" as endpoint
end box
box "Backend — Community Application and Domain" #ECFDF3
  participant "PreserveCommunityIntegrityHandler" as handler
  participant "PreserveCommunityIntegrityPolicy" as policy
end box
box "Backend — Community Infrastructure" #FFF4E5
  database "Community Database" as store
  participant "PreserveCommunityIntegrityProjector" as projector
end box

actor -> surface : Start enforce limits and concurrency
surface -> client : Build typed request
client -> endpoint : Submit request
endpoint -> endpoint : Authenticate and apply boundary policy
endpoint -> handler : Send PreserveCommunityIntegrityRequest
handler -> store : Load current scoped state
store --> handler : Current state and version
handler -> policy : Enforce L2-COMM-012 — enforce limits and concurrency
policy --> handler : Typed decision
alt Decision is accepted
  opt Requirement changes authoritative state
    handler -> store : Commit state and outcome conditionally
    store --> handler : Commit result
  end
  opt Committed outcome has derived effects
    handler -> projector : Publish committed outcome
    projector --> handler : Accepted for idempotent processing
  end
  handler --> endpoint : Accepted feature result
else Decision is rejected or stale
  handler --> endpoint : Safe validation, denial, or conflict result
end
endpoint --> client : Typed response
client --> surface : Reconciled feature result
surface --> actor : Present current outcome
@enduml
