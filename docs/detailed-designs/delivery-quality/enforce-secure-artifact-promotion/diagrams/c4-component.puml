@startuml
!include <C4/C4_Component>
LAYOUT_WITH_LEGEND()
title Components — Enforce one secure build-and-promotion pipeline

Container(frontend, "Engineering Workbench", "CLI and repository tools", "Presents state and sends typed intent")
Container_Boundary(backend, "Delivery Control Plane") {
  Component(endpoint, "EnforceSecureArtifactPromotionEndpoint", "pipeline entry point", "Authenticates and dispatches feature requests")
  Component(handler, "EnforceSecureArtifactPromotionHandler", "Application service", "Coordinates authorized state and one unit of work")
  Component(policy, "EnforceSecureArtifactPromotionPolicy", "Domain policy", "Evaluates traced behavior against current state")
  Component(repository, "IEnforceSecureArtifactPromotionRepository", "Persistence port", "Loads scoped state and commits conditionally")
  Component(projector, "EnforceSecureArtifactPromotionProjector", "Post-commit component", "Processes committed outcomes idempotently")
  ComponentDb(store, "Evidence Registry", "Versioned artifact metadata", "Stores state, versions, outcomes, and checkpoints")
}

Rel(frontend, endpoint, "Submits EnforceSecureArtifactPromotionRequest", "Typed contract")
Rel(endpoint, handler, "Dispatches request")
Rel(handler, policy, "Evaluates current state")
Rel(handler, repository, "Loads and commits")
Rel(repository, store, "Reads and writes", "Transactional adapter")
Rel(handler, projector, "Publishes committed outcome", "Durable handoff")
Rel(projector, store, "Checkpoints processing", "Idempotent adapter")
@enduml
