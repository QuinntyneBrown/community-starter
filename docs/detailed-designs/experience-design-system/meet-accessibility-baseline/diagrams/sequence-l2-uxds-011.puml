@startuml
title UML sequence behaviour — Dynamic status and responsive composition remain accessible
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Product Engineer" as actor
box "Frontend — Component Workbench" #E0F2FE
  participant "MeetAccessibilityBaselineSurface" as surface
  participant "MeetAccessibilityBaselineClient" as client
end box
box "Backend — Design Validation Pipeline" #D1FADF
  participant "MeetAccessibilityBaselineEndpoint" as endpoint
end box
box "Backend — Design Tokens and Component Policy" #ECFDF3
  participant "MeetAccessibilityBaselineHandler" as handler
  participant "MeetAccessibilityBaselinePolicy" as policy
end box
box "Backend — Design Artifact Infrastructure" #FFF4E5
  database "Design Artifact Registry" as store
  participant "MeetAccessibilityBaselineProjector" as projector
end box

actor -> surface : Start dynamic status and responsive composition remain accessible
surface -> client : Build typed request
client -> endpoint : Submit request
endpoint -> endpoint : Authenticate and apply boundary policy
endpoint -> handler : Send MeetAccessibilityBaselineRequest
handler -> store : Load current scoped state
store --> handler : Current state and version
handler -> policy : Enforce L2-UXDS-011 — dynamic status and responsive composition remain accessible
policy --> handler : Typed decision
alt Decision is accepted
  opt Requirement changes authoritative state
    handler -> store : Commit state and outcome conditionally
    store --> handler : Commit result
  end
  opt Committed outcome has derived effects
    handler -> projector : Publish committed outcome
    projector --> handler : Accepted for idempotent processing
  end
  handler --> endpoint : Accepted feature result
else Decision is rejected or stale
  handler --> endpoint : Safe validation, denial, or conflict result
end
endpoint --> client : Typed response
client --> surface : Reconciled feature result
surface --> actor : Present current outcome
@enduml
