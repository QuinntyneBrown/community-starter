@startuml
!include <C4/C4_Component>
LAYOUT_WITH_LEGEND()
title Components — Relevant and private Notifications

Container(frontend, "Member Web Application", "Angular", "Presents state and sends typed intent")
Container_Boundary(backend, "Community API") {
  Component(endpoint, "DeliverPrivateNotificationsEndpoint", "HTTP endpoint", "Authenticates and dispatches feature requests")
  Component(handler, "DeliverPrivateNotificationsHandler", "Application service", "Coordinates authorized state and one unit of work")
  Component(policy, "DeliverPrivateNotificationsPolicy", "Domain policy", "Evaluates traced behavior against current state")
  Component(repository, "IDeliverPrivateNotificationsRepository", "Persistence port", "Loads scoped state and commits conditionally")
  Component(projector, "DeliverPrivateNotificationsProjector", "Post-commit component", "Processes committed outcomes idempotently")
  ComponentDb(store, "Community Database", "Relational database", "Stores state, versions, outcomes, and checkpoints")
}

Rel(frontend, endpoint, "Submits DeliverPrivateNotificationsRequest", "Typed contract")
Rel(endpoint, handler, "Dispatches request")
Rel(handler, policy, "Evaluates current state")
Rel(handler, repository, "Loads and commits")
Rel(repository, store, "Reads and writes", "Transactional adapter")
Rel(handler, projector, "Publishes committed outcome", "Durable handoff")
Rel(projector, store, "Checkpoints processing", "Idempotent adapter")
@enduml
