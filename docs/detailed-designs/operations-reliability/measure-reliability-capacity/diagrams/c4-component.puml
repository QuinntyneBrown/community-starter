@startuml
!include <C4/C4_Component>
LAYOUT_WITH_LEGEND()
title Components — Reliability and capacity are measurable

Container(frontend, "Operations Console", "Web dashboard and runbook tools", "Presents state and sends typed intent")
Container_Boundary(backend, "Operations Control API") {
  Component(endpoint, "MeasureReliabilityCapacityEndpoint", "operations command endpoint", "Authenticates and dispatches feature requests")
  Component(handler, "MeasureReliabilityCapacityHandler", "Application service", "Coordinates authorized state and one unit of work")
  Component(policy, "MeasureReliabilityCapacityPolicy", "Domain policy", "Evaluates traced behavior against current state")
  Component(repository, "IMeasureReliabilityCapacityRepository", "Persistence port", "Loads scoped state and commits conditionally")
  Component(projector, "MeasureReliabilityCapacityProjector", "Post-commit component", "Processes committed outcomes idempotently")
  ComponentDb(store, "Operations Evidence Store", "Relational and object storage", "Stores state, versions, outcomes, and checkpoints")
}

Rel(frontend, endpoint, "Submits MeasureReliabilityCapacityRequest", "Typed contract")
Rel(endpoint, handler, "Dispatches request")
Rel(handler, policy, "Evaluates current state")
Rel(handler, repository, "Loads and commits")
Rel(repository, store, "Reads and writes", "Transactional adapter")
Rel(handler, projector, "Publishes committed outcome", "Durable handoff")
Rel(projector, store, "Checkpoints processing", "Idempotent adapter")
@enduml
