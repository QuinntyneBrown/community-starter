@startuml
title UML sequence behaviour — C# code is nullable-safe, asynchronous, and convention-enforced
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Product Engineer" as actor
box "Frontend — Engineering Workbench" #E0F2FE
  participant "EnforceImplementationDisciplineSurface" as surface
  participant "EnforceImplementationDisciplineClient" as client
end box
box "Backend — Delivery Control Plane" #D1FADF
  participant "EnforceImplementationDisciplineEndpoint" as endpoint
end box
box "Backend — Delivery Policy and Evidence" #ECFDF3
  participant "EnforceImplementationDisciplineHandler" as handler
  participant "EnforceImplementationDisciplinePolicy" as policy
end box
box "Backend — Build and Artifact Infrastructure" #FFF4E5
  database "Evidence Registry" as store
  participant "EnforceImplementationDisciplineProjector" as projector
end box

actor -> surface : Start C# code is nullable-safe, asynchronous, and convention-enforced
surface -> client : Build typed request
client -> endpoint : Submit request
endpoint -> endpoint : Authenticate and apply boundary policy
endpoint -> handler : Send EnforceImplementationDisciplineRequest
handler -> store : Load current scoped state
store --> handler : Current state and version
handler -> policy : Enforce L2-ARCH-010 — C# code is nullable-safe, asynchronous, and convention-enforced
policy --> handler : Typed decision
alt Decision is accepted
  opt Requirement changes authoritative state
    handler -> store : Commit state and outcome conditionally
    store --> handler : Commit result
  end
  opt Committed outcome has derived effects
    handler -> projector : Publish committed outcome
    projector --> handler : Accepted for idempotent processing
  end
  handler --> endpoint : Accepted feature result
else Decision is rejected or stale
  handler --> endpoint : Safe validation, denial, or conflict result
end
endpoint --> client : Typed response
client --> surface : Reconciled feature result
surface --> actor : Present current outcome
@enduml
