@startuml
title UML sequence behaviour — Browser and transport headers match the deployment threat model
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Security Engineer" as actor
box "Frontend — Security Operations Console" #E0F2FE
  participant "HardenRuntimeSupplyChainSurface" as surface
  participant "HardenRuntimeSupplyChainClient" as client
end box
box "Backend — Security Control API" #D1FADF
  participant "HardenRuntimeSupplyChainEndpoint" as endpoint
end box
box "Backend — Security Policy and Enforcement" #ECFDF3
  participant "HardenRuntimeSupplyChainHandler" as handler
  participant "HardenRuntimeSupplyChainPolicy" as policy
end box
box "Backend — Key, Audit, and Scan Infrastructure" #FFF4E5
  database "Security Evidence Store" as store
  participant "HardenRuntimeSupplyChainProjector" as projector
end box

actor -> surface : Start browser and transport headers match the deployment threat model
surface -> client : Build typed request
client -> endpoint : Submit request
endpoint -> endpoint : Authenticate and apply boundary policy
endpoint -> handler : Send HardenRuntimeSupplyChainRequest
handler -> store : Load current scoped state
store --> handler : Current state and version
handler -> policy : Enforce L2-SECU-010 — browser and transport headers match the deployment threat model
policy --> handler : Typed decision
alt Decision is accepted
  opt Requirement changes authoritative state
    handler -> store : Commit state and outcome conditionally
    store --> handler : Commit result
  end
  opt Committed outcome has derived effects
    handler -> projector : Publish committed outcome
    projector --> handler : Accepted for idempotent processing
  end
  handler --> endpoint : Accepted feature result
else Decision is rejected or stale
  handler --> endpoint : Safe validation, denial, or conflict result
end
endpoint --> client : Typed response
client --> surface : Reconciled feature result
surface --> actor : Present current outcome
@enduml
