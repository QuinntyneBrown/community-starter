---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Explore communities — Community Starter"
  description="Find a Community Starter community."
>
  <header class="page-heading cs-shell">
    <p class="cs-eyebrow">Explore</p>
    <h1>Find a community where you can belong and contribute.</h1>
  </header>
  <section class="cs-shell reading" aria-labelledby="community-status">
    <h2 id="community-status">Public communities are coming soon</h2>
    <p>
      Communities are private by default. Public listings appear only after an
      owner deliberately enables an approved, privacy-safe preview.
    </p>
    <a class="cs-button" href="/app/register">Create an account</a>
  </section>
</SiteLayout>
