---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="Community Starter — Find your people and build together"
  description="A community platform for finding people, sharing useful work, and building safer local communities."
>
  <section class="hero cs-shell">
    <p class="cs-eyebrow">Community with purpose</p>
    <h1 class="hero__title">Find your people. <em>Build together.</em></h1>
    <p class="hero__copy">
      Community Starter helps people gather around shared purpose, contribute
      useful work, and care for one another with clear expectations and safer
      participation.
    </p>
    <div class="hero__actions">
      <a class="cs-button" href="/app/register">Create an account</a>
      <a class="cs-button cs-button--secondary" href="/communities"
        >Explore communities</a
      >
    </div>
  </section>

  <section class="feature-band">
    <div class="cs-shell">
      <p class="cs-eyebrow">What becomes possible</p>
      <div class="feature-grid">
        <article class="feature-card">
          <h2>Belong</h2>
          <p>
            Discover a community, understand its purpose, and join through a
            clear path.
          </p>
        </article>
        <article class="feature-card">
          <h2>Contribute</h2>
          <p>
            Share posts, conversations, and events while keeping context and
            consent visible.
          </p>
        </article>
        <article class="feature-card">
          <h2>Care</h2>
          <p>
            Use transparent governance, privacy controls, and proportionate
            safety practices.
          </p>
        </article>
      </div>
    </div>
  </section>
</SiteLayout>
