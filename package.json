{
  "name": "community-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.18.0",
    "npm": "11.6.2"
  },
  "workspaces": [
    "frontend",
    "marketing"
  ],
  "scripts": {
    "build": "npm run build --workspace marketing && npm run build --workspace frontend",
    "test:specialization": "python -m unittest discover -s scripts/tests -p test_*.py",
    "test": "npm run test --workspace frontend -- --watch=false",
    "test:e2e": "playwright test --config frontend/playwright.config.ts",
    "format:check": "npx prettier --check \"{frontend,marketing,design-system}/**/*.{ts,html,scss,css,json,md,astro}\"",
    "dev:app": "npm run start --workspace frontend",
    "dev:marketing": "npm run dev --workspace marketing"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@playwright/test": "1.61.1",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "@modelcontextprotocol/sdk": "1.26.0",
    "esbuild": "0.28.1"
  }
}
